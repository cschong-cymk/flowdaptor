# Copy this file to .env and fill in real values. Never commit .env.

# Symfony Mailer DSN — see https://symfony.com/doc/current/mailer.html#using-a-3rd-party-transport
# Examples:
#   smtp://user:pass@smtp.example.com:587
#   smtp://AKIA...:secret@email-smtp.ap-southeast-1.amazonaws.com:587
#   smtp://apikey:SG.xxx@smtp.sendgrid.net:587
MAILER_DSN=smtp://user:pass@smtp.example.com:587

# From address shown on outgoing mail. Must be a domain the SMTP provider lets you send from.
MAIL_FROM="FlowDaptor Website <no-reply@flowdaptor.com>"

# Recipient — where contact-form submissions are delivered.
MAIL_TO=enterprise@flowdaptor.com

# Optional reply-to override. Leave blank to use the visitor's submitted email.
MAIL_REPLY_TO=
